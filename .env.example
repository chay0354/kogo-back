# Copy into Vercel Project → Settings → Environment Variables (Production / Preview).
# For local dev, copy to `.env` in this folder (never commit `.env`).

SECRET_KEY=
DEBUG=false

# Comma-separated hosts (include your Vercel deployment hostname, e.g. kogo-back-xxxx.vercel.app)
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Postgres (Supabase / Neon / Vercel Postgres, etc.)
DATABASE_URL=

# Frontend origins (comma-separated). On Vercel, https://*.vercel.app is also allowed via regex unless
# CORS_DISABLE_VERCEL_REGEX=true.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Extra CSRF origins for the browser app (comma-separated full origins with scheme)
CSRF_TRUSTED_ORIGINS_EXTRA=https://your-app.vercel.app,http://localhost:3000

# Optional: set true to disable *.vercel.app CORS regex (then list every preview URL in CORS_ALLOWED_ORIGINS)
# CORS_DISABLE_VERCEL_REGEX=false

# Payments / integrations (set real values in production)
TRANZILA_TERMINAL=
TRANZILA_SUPPLIER=
TRANZILA_PUBLIC_KEY=
TRANZILA_SECRET_KEY=
TRANZILA_WEBHOOK_SECRET=
TRANZILA_API_BASE_URL=https://api.tranzila.com
TRANZILA_BASE_URL=https://direct.tranzila.com
TRANZILA_ENVIRONMENT=production

# Supabase (optional; used by dashboard / server features)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Celery: not available as a long-running worker on Vercel; point to Redis only if you run workers elsewhere
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
